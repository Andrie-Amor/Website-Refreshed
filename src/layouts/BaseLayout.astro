---
import "../styles/global.css";

const { title = "My Site", fullBleed = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <title>{title}</title>
  </head>
  <body>
    <header class="navbar">
      <div class="container">
        <a href="/" class="site-title">Andre Amor</a>
        <nav>
          <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/reading">Reading List</a></li>
            <li><a href="/coffee-map">Coffee Map</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main class={fullBleed ? "page-shell page-shell--full" : "container"}>
      <slot />
    </main>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", async () => {
        const list = document.querySelector(".subtopic-list ul");
        if (!list) return;
        for (const link of list.querySelectorAll("li > a.subtopic-link")) {
          const href = link.getAttribute("href");
          try {
            const res = await fetch(`${href}/content.html`);
            if (!res.ok) continue;
            const html = await res.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, "text/html");
            const headers = doc.querySelectorAll("h2[id]");
            if (headers.length) {
              const ul = document.createElement("ul");
              ul.className = "subtopic-sections";
              headers.forEach((h2) => {
                const li = document.createElement("li");
                const a = document.createElement("a");
                a.href = `${href}#${h2.id}`;
                a.textContent = h2.textContent;
                li.appendChild(a);
                ul.appendChild(li);
              });
              link.parentElement.appendChild(ul);
            }
          } catch {}
        }
      });
    </script>
  </body>
</html>
