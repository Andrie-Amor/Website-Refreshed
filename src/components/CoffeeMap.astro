---
import "leaflet/dist/leaflet.css";
import type { CoffeeShop } from "../data/coffeeShops";

interface Props {
  title?: string;
  cityLabel?: string;
  shops: CoffeeShop[];
  center?: [number, number];
}

const {
  title = "Favorite Coffee Shops",
  cityLabel = "San Francisco, California",
  shops,
  center = [-122.433, 37.764],
} = Astro.props;

const mapId = "favorite-coffee-map";
---

<section
  id="coffee-map"
  class="coffee-map-section"
  aria-labelledby="coffee-map-title"
  data-map-root={mapId}
  data-center={JSON.stringify(center)}
  data-shops={JSON.stringify(shops)}
>
  <div class="coffee-map-frame">
    <div class="coffee-map-canvas" id={mapId} data-map-canvas></div>

    <button
      class="coffee-sidebar-reopen"
      type="button"
      aria-controls="coffee-map-sidebar"
      aria-label="Open sidebar"
      data-sidebar-reopen
    ></button>

    <aside
      id="coffee-map-sidebar"
      class="coffee-map-sidebar"
      data-sidebar
      aria-label="Coffee shop list"
    >
      <div class="coffee-map-sidebar__header">
        <p class="coffee-map-sidebar__eyebrow">{cityLabel}</p>
        <h2 id="coffee-map-title">{title}</h2>
      </div>

      <div class="coffee-map-sidebar__list" data-shop-list>
        {
          shops.map((shop, index) => (
            <button
              class={`coffee-shop-item ${index === 0 ? "is-active" : ""}`}
              type="button"
              data-shop-item
              data-shop-id={shop.id}
              style={`--shop-accent: ${shop.accent};`}
            >
              <span class="coffee-shop-item__badge">{shop.monogram}</span>
              <span class="coffee-shop-item__text">
                <span class="coffee-shop-item__name">{shop.name}</span>
                {shop.description && (
                  <span class="coffee-shop-item__description">
                    {shop.description}
                  </span>
                )}
              </span>
            </button>
          ))
        }
      </div>

      <div
        class="coffee-sidebar-edge"
        role="separator"
        aria-controls="coffee-map-sidebar"
        aria-label="Resize sidebar"
        aria-orientation="vertical"
        tabindex="0"
        data-sidebar-resizer
      ></div>
    </aside>
  </div>
</section>

<script>
  import L from "leaflet";

  const root = document.querySelector('[data-map-root="favorite-coffee-map"]');

  if (root instanceof HTMLElement) {
    const shops = JSON.parse(root.dataset.shops ?? "[]");
    const center = JSON.parse(root.dataset.center ?? "[-122.433, 37.764]");
    const mapContainer = root.querySelector("[data-map-canvas]");
    const sidebar = root.querySelector("[data-sidebar]");
    const sidebarResizer = root.querySelector("[data-sidebar-resizer]");
    const sidebarReopen = root.querySelector("[data-sidebar-reopen]");
    const listItems = Array.from(root.querySelectorAll("[data-shop-item]"));

    if (
      mapContainer instanceof HTMLElement &&
      sidebar instanceof HTMLElement &&
      sidebarResizer instanceof HTMLElement &&
      sidebarReopen instanceof HTMLButtonElement &&
      mapContainer.dataset.initialized !== "true"
    ) {
      mapContainer.dataset.initialized = "true";

      const tileUrl = "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png";
      const DEFAULT_SIDEBAR_WIDTH = 352;
      const MIN_SIDEBAR_WIDTH = 248;
      const MAX_SIDEBAR_WIDTH = 448;
      const HIDE_SIDEBAR_THRESHOLD = 180;
      let currentSidebarWidth = DEFAULT_SIDEBAR_WIDTH;

      const map = L.map(mapContainer, {
        center: [center[1], center[0]],
        zoom: 11,
        zoomControl: false,
        attributionControl: false,
        scrollWheelZoom: false,
        doubleClickZoom: false,
        keyboard: false,
        zoomSnap: 1,
        zoomDelta: 1,
        minZoom: 9,
        zoomAnimation: true,
        zoomAnimationThreshold: 1,
        fadeAnimation: true,
        markerZoomAnimation: true,
      });

      L.control
        .attribution({
          position: "bottomleft",
          prefix: false,
        })
        .addTo(map);
      L.tileLayer(tileUrl, {
        subdomains: "abcd",
        maxZoom: 20,
        detectRetina: true,
        keepBuffer: 8,
        updateWhenZooming: true,
        updateInterval: 120,
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors, &copy; <a href="https://carto.com/attributions">CARTO</a>',
      }).addTo(map);

      const clampZoom = (zoom) =>
        Math.min(map.getMaxZoom(), Math.max(map.getMinZoom(), zoom));
      const PINCH_ZOOM_STEP = 1;
      const PINCH_THRESHOLD = 80;
      let pinchDelta = 0;
      let pinchResetTimer = null;
      let pinchGestureConsumed = false;
      let queuedZoomSteps = 0;
      let queuedZoomPoint = null;
      let isQueuedZoomActive = false;

      const processQueuedZoom = () => {
        if (isQueuedZoomActive || queuedZoomSteps === 0) return;

        const direction = Math.sign(queuedZoomSteps);
        const nextZoom = clampZoom(map.getZoom() + direction * PINCH_ZOOM_STEP);

        queuedZoomSteps -= direction;

        if (nextZoom === map.getZoom()) {
          queuedZoomSteps = 0;
          return;
        }

        isQueuedZoomActive = true;
        map.setZoomAround(
          queuedZoomPoint ?? map.getSize().divideBy(2),
          nextZoom,
        );
      };

      map.on("zoomend", () => {
        if (!isQueuedZoomActive) return;

        isQueuedZoomActive = false;

        if (queuedZoomSteps !== 0) {
          processQueuedZoom();
        }
      });

      const handleTrackpadPinchZoom = (event) => {
        // Trackpad pinch gestures surface as ctrl+wheel on desktop browsers.
        if (!event.ctrlKey) return;

        event.preventDefault();

        const rect = mapContainer.getBoundingClientRect();
        const zoomDelta = -event.deltaY * 0.01;
        const containerPoint = L.point(
          event.clientX - rect.left,
          event.clientY - rect.top,
        );
        const nextDelta = pinchDelta - event.deltaY;
        const steps = Math.trunc(nextDelta / PINCH_THRESHOLD);

        pinchDelta = nextDelta;

        if (steps !== 0 && !pinchGestureConsumed) {
          pinchDelta -= steps * PINCH_THRESHOLD;
          pinchGestureConsumed = true;
          queuedZoomSteps = Math.sign(steps);
          queuedZoomPoint = containerPoint;
          processQueuedZoom();
        }

        window.clearTimeout(pinchResetTimer ?? undefined);
        pinchResetTimer = window.setTimeout(() => {
          pinchDelta = 0;
          pinchGestureConsumed = false;
          pinchResetTimer = null;
        }, 140);
      };

      mapContainer.addEventListener("wheel", handleTrackpadPinchZoom, {
        passive: false,
      });

      const markerElements = new Map();
      const markersById = new Map();
      const bounds =
        shops.length > 0
          ? L.latLngBounds(
              shops.map((shop) => [shop.coordinates[1], shop.coordinates[0]]),
            )
          : null;

      const isCompact = () => window.matchMedia("(max-width: 900px)").matches;
      const isSidebarHidden = () => root.classList.contains("is-sidebar-hidden");
      const getSidebarMaxWidth = () =>
        Math.max(
          MIN_SIDEBAR_WIDTH,
          Math.min(MAX_SIDEBAR_WIDTH, window.innerWidth - 48),
        );
      const clampSidebarWidth = (width) =>
        Math.min(getSidebarMaxWidth(), Math.max(MIN_SIDEBAR_WIDTH, width));
      const syncSidebarWidth = () => {
        const width = clampSidebarWidth(currentSidebarWidth);

        currentSidebarWidth = width;
        root.style.setProperty("--sidebar-width", `${width}px`);
        sidebarResizer.setAttribute("aria-valuemin", String(MIN_SIDEBAR_WIDTH));
        sidebarResizer.setAttribute("aria-valuemax", String(getSidebarMaxWidth()));
        sidebarResizer.setAttribute("aria-valuenow", String(Math.round(width)));
      };
      const syncSidebarVisibility = () => {
        const hidden = !isCompact() && isSidebarHidden();
        sidebar.setAttribute("aria-hidden", String(hidden));
        sidebarReopen.setAttribute("aria-hidden", String(!hidden));
      };
      const showSidebar = () => {
        if (isCompact()) return;
        root.classList.remove("is-sidebar-hidden", "is-sidebar-collapsing");
        syncSidebarWidth();
        syncSidebarVisibility();
      };
      const hideSidebar = () => {
        if (isCompact()) return;
        root.classList.remove("is-sidebar-collapsing");
        root.classList.add("is-sidebar-hidden");
        syncSidebarVisibility();
      };

      const getPadding = () => {
        if (isCompact() || isSidebarHidden()) {
          return { top: 28, right: 28, bottom: 28, left: 28 };
        }

        return {
          top: 56,
          right: 56,
          bottom: 56,
          left: currentSidebarWidth + 40,
        };
      };

      const fitToMarkers = (duration) => {
        if (!bounds) return;
        const padding = getPadding();

        map.fitBounds(bounds, {
          paddingTopLeft: [padding.left, padding.top],
          paddingBottomRight: [padding.right, padding.bottom],
          maxZoom: 13,
          animate: duration > 0,
        });
      };

      const activePopup = L.popup({
        closeButton: false,
        autoClose: false,
        closeOnClick: false,
        autoPan: false,
        className: "coffee-map-popup",
        offset: [0, -26],
      });

      const createPopupContent = (shop) => {
        const popupContent = document.createElement("article");
        popupContent.className = "coffee-map-popup__content";
        popupContent.style.setProperty("--popup-accent", shop.accent);

        const popupTitle = document.createElement("h3");
        popupTitle.textContent = shop.name;

        popupContent.append(popupTitle);

        if (shop.description) {
          const popupDescription = document.createElement("p");
          popupDescription.textContent = shop.description;
          popupContent.append(popupDescription);
        }

        return popupContent;
      };

      const centerOnShop = (shop) => {
        const padding = getPadding();
        const zoom = map.getZoom();
        const targetLatLng = L.latLng(shop.coordinates[1], shop.coordinates[0]);
        const projectedPoint = map.project(targetLatLng, zoom);
        const offsetPoint = L.point(
          (padding.left - padding.right) / 2,
          (padding.top - padding.bottom) / 2,
        );
        const centeredLatLng = map.unproject(
          projectedPoint.subtract(offsetPoint),
          zoom,
        );

        map.flyTo(centeredLatLng, zoom, {
          animate: true,
          duration: 0.85,
        });
      };

      const setActiveShop = (shop, options = {}) => {
        const { revealSidebar = false, centerMap = false } = options;

        if (revealSidebar) {
          showSidebar();
        }

        if (centerMap) {
          centerOnShop(shop);
        }

        markerElements.forEach((markerElement, shopId) => {
          markerElement.classList.toggle("is-active", shopId === shop.id);
        });

        const activeMarker = markersById.get(shop.id);
        if (activeMarker) {
          activePopup
            .setLatLng([shop.coordinates[1], shop.coordinates[0]])
            .setContent(createPopupContent(shop));

          if (!map.hasLayer(activePopup)) {
            activePopup.addTo(map);
          }
        }

        for (const item of listItems) {
          const isActive = item instanceof HTMLElement && item.dataset.shopId === shop.id;
          item.classList.toggle("is-active", isActive);
          if (isActive) {
            item.scrollIntoView({ block: "nearest", behavior: "smooth" });
            if (revealSidebar && !isCompact()) {
              requestAnimationFrame(() => item.focus({ preventScroll: true }));
            }
          }
        }
      };

      const addMarkers = () => {
        for (const shop of shops) {
          const markerElement = document.createElement("button");
          markerElement.type = "button";
          markerElement.className = "coffee-marker";
          markerElement.setAttribute("aria-label", shop.name);
          markerElement.style.setProperty("--marker-accent", shop.accent);
          markerElement.innerHTML = `
            <span class="coffee-marker__halo"></span>
            <span class="coffee-marker__core">
              <span class="coffee-marker__label">${shop.monogram}</span>
            </span>
          `;

          const marker = L.marker([shop.coordinates[1], shop.coordinates[0]], {
            title: shop.name,
            alt: shop.name,
            keyboard: false,
            riseOnHover: true,
            icon: L.divIcon({
              html: markerElement.outerHTML,
              className: "coffee-marker-wrapper",
              iconSize: [54, 54],
              iconAnchor: [27, 27],
            }),
          })
            .addTo(map)
            .on("click", () => setActiveShop(shop, { revealSidebar: true }));

          markersById.set(shop.id, marker);

          const liveMarker = marker.getElement()?.querySelector(".coffee-marker");
          if (liveMarker instanceof HTMLElement) {
            markerElements.set(shop.id, liveMarker);
          }
        }
      };

      for (const item of listItems) {
        item.addEventListener("click", () => {
          const shop = shops.find((entry) => entry.id === item.dataset.shopId);
          if (shop) {
            setActiveShop(shop, { revealSidebar: true, centerMap: true });
          }
        });
      }

      syncSidebarWidth();
      syncSidebarVisibility();

      let activePointerId = null;
      let dragStartX = 0;
      let dragStartWidth = currentSidebarWidth;
      let dragCurrentWidth = currentSidebarWidth;

      const resizeSidebar = (nextWidth) => {
        currentSidebarWidth = clampSidebarWidth(nextWidth);
        syncSidebarWidth();
      };

      const stopResizingSidebar = () => {
        if (activePointerId === null) return;

        if (dragCurrentWidth <= HIDE_SIDEBAR_THRESHOLD) {
          hideSidebar();
        } else {
          root.classList.remove("is-sidebar-collapsing");
        }

        root.classList.remove("is-resizing-sidebar");
        sidebarResizer.releasePointerCapture(activePointerId);
        activePointerId = null;
      };

      sidebarResizer.addEventListener("pointerdown", (event) => {
        if (isCompact() || isSidebarHidden() || event.button !== 0) return;

        activePointerId = event.pointerId;
        dragStartX = event.clientX;
        dragStartWidth = currentSidebarWidth;
        dragCurrentWidth = currentSidebarWidth;
        root.classList.add("is-resizing-sidebar");
        sidebarResizer.setPointerCapture(event.pointerId);
        event.preventDefault();
      });

      sidebarResizer.addEventListener("pointermove", (event) => {
        if (activePointerId !== event.pointerId) return;

        dragCurrentWidth = dragStartWidth + (event.clientX - dragStartX);
        root.classList.toggle(
          "is-sidebar-collapsing",
          dragCurrentWidth <= HIDE_SIDEBAR_THRESHOLD,
        );

        if (dragCurrentWidth <= HIDE_SIDEBAR_THRESHOLD) {
          resizeSidebar(MIN_SIDEBAR_WIDTH);
          return;
        }

        resizeSidebar(dragCurrentWidth);
      });

      sidebarResizer.addEventListener("pointerup", stopResizingSidebar);
      sidebarResizer.addEventListener("pointercancel", stopResizingSidebar);

      sidebarResizer.addEventListener("keydown", (event) => {
        if (isCompact()) return;

        if (event.key === "ArrowLeft") {
          if (currentSidebarWidth - 24 <= HIDE_SIDEBAR_THRESHOLD) {
            hideSidebar();
          } else {
            resizeSidebar(currentSidebarWidth - 24);
          }
          event.preventDefault();
        }

        if (event.key === "ArrowRight") {
          showSidebar();
          resizeSidebar(currentSidebarWidth + 24);
          event.preventDefault();
        }
      });

      sidebarReopen.addEventListener("click", () => {
        showSidebar();
        map.invalidateSize();
      });

      const resizeObserver = new ResizeObserver(() => {
        map.invalidateSize();
      });

      resizeObserver.observe(mapContainer);
      window.addEventListener("resize", () => {
        if (isCompact()) {
          root.classList.remove("is-sidebar-hidden", "is-sidebar-collapsing");
        }
        syncSidebarWidth();
        syncSidebarVisibility();
        map.invalidateSize();
      });
      window.addEventListener("pagehide", () => {
        resizeObserver.disconnect();
        window.clearTimeout(pinchResetTimer ?? undefined);
        map.remove();
      });

      map.whenReady(() => {
        addMarkers();

        if (shops[0]) {
          setActiveShop(shops[0]);
        }

        fitToMarkers(0);
        requestAnimationFrame(() => map.invalidateSize());
        requestAnimationFrame(() => fitToMarkers(1600));
      });
    }
  }
</script>

<style is:global>
  .coffee-map-section {
    --sidebar-width: 22rem;
    --shop-list-inline-gap: 0.7rem;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
  }

  .coffee-map-frame {
    position: relative;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    border-top: 1px solid #e5e5e5;
    background: #fff;
  }

  .coffee-map-canvas {
    position: absolute;
    inset: 0;
  }

  .coffee-map-sidebar {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: min(var(--sidebar-width), calc(100vw - 3rem));
    padding: 1rem;
    background: rgba(249, 249, 249, 0.94);
    border-right: 1px solid rgba(229, 229, 229, 0.96);
    box-shadow: 12px 0 32px rgba(0, 0, 0, 0.06);
    backdrop-filter: blur(18px);
    transform: translateX(0);
    opacity: 1;
    transition:
      transform 220ms ease,
      opacity 180ms ease;
  }

  .coffee-map-section.is-sidebar-hidden .coffee-map-sidebar {
    transform: translateX(calc(-100% - 1.5rem));
    opacity: 0;
    pointer-events: none;
  }

  .coffee-map-section.is-sidebar-collapsing .coffee-map-sidebar {
    opacity: 0.82;
  }

  .coffee-sidebar-reopen {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1001;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid rgba(229, 229, 229, 0.96);
    border-radius: 999px;
    background: rgba(249, 249, 249, 0.96);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(14px);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.9);
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      background-color 180ms ease;
  }

  .coffee-sidebar-reopen::before,
  .coffee-sidebar-reopen::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 999px;
    background: #666;
    transform: translate(-50%, -50%);
  }

  .coffee-sidebar-reopen::before {
    width: 0.9rem;
    height: 2px;
  }

  .coffee-sidebar-reopen::after {
    width: 2px;
    height: 0.9rem;
  }

  .coffee-map-section.is-sidebar-hidden .coffee-sidebar-reopen {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .coffee-sidebar-reopen:hover,
  .coffee-sidebar-reopen:focus-visible {
    background: rgba(255, 255, 255, 0.99);
  }

  .coffee-sidebar-reopen:focus-visible {
    outline: none;
  }

  .coffee-sidebar-edge {
    position: absolute;
    top: 0;
    right: -0.375rem;
    bottom: 0;
    z-index: 1002;
    width: 0.75rem;
    padding: 0;
    cursor: ew-resize;
    touch-action: none;
    background: transparent;
  }

  .coffee-sidebar-edge::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0.375rem;
    bottom: 0;
    width: 1px;
    background: rgba(229, 229, 229, 0.96);
    transition: background-color 180ms ease;
  }

  .coffee-sidebar-edge:hover::before,
  .coffee-sidebar-edge:focus-visible::before,
  .coffee-map-section.is-resizing-sidebar .coffee-sidebar-edge::before {
    background: rgba(176, 176, 176, 0.96);
  }

  .coffee-sidebar-edge:focus-visible {
    outline: none;
  }

  .coffee-map-sidebar__header {
    padding: 0.15rem 0.15rem 0 0.15rem;
  }

  .coffee-map-sidebar__eyebrow {
    margin: 0 0 0.45rem;
    color: #666;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .coffee-map-sidebar__header h2 {
    margin: 0;
    color: #333;
    font-size: clamp(1.65rem, 3vw, 2.2rem);
    line-height: 1;
  }

  .coffee-map-sidebar__list {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.5rem;
    min-height: 0;
    overflow-y: auto;
    padding-top: 0.35rem;
    padding-right: var(--shop-list-inline-gap);
    padding-bottom: 0.2rem;
    scrollbar-gutter: stable;
  }

  .coffee-shop-item {
    display: grid;
    grid-template-columns: 2.8rem 1fr;
    gap: 0.8rem;
    align-items: start;
    width: 100%;
    padding: 0.8rem;
    border: 1px solid rgba(229, 229, 229, 0.96);
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.82);
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .coffee-shop-item:hover,
  .coffee-shop-item:focus-visible,
  .coffee-shop-item.is-active {
    border-color: color-mix(in srgb, var(--shop-accent) 24%, #d9d9d9);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
    transform: translateY(-1px);
  }

  .coffee-shop-item:focus-visible {
    outline: none;
  }

  .coffee-shop-item__badge {
    display: grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 999px;
    background: var(--shop-accent);
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    box-shadow:
      0 10px 24px color-mix(in srgb, var(--shop-accent) 20%, transparent),
      0 0 0 2px rgba(255, 255, 255, 0.94);
  }

  .coffee-shop-item__text {
    display: grid;
    gap: 0.28rem;
  }

  .coffee-shop-item__name {
    color: #333;
    font-size: 0.98rem;
    font-weight: 700;
  }

  .coffee-shop-item__description {
    color: #666;
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .coffee-marker {
    --marker-accent: #b77b5c;
    position: relative;
    width: 3.4rem;
    height: 3.4rem;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    transition: transform 180ms ease;
  }

  .coffee-marker:hover,
  .coffee-marker:focus-visible,
  .coffee-marker.is-active {
    transform: scale(1.08);
  }

  .coffee-marker__halo,
  .coffee-marker__core {
    position: absolute;
    inset: 0;
    border-radius: 999px;
  }

  .coffee-marker__halo {
    background: color-mix(in srgb, var(--marker-accent) 26%, white);
    transform: scale(1.12);
    opacity: 0.82;
    transition:
      transform 200ms ease,
      opacity 200ms ease;
  }

  .coffee-marker__core {
    display: grid;
    place-items: center;
    background: var(--marker-accent);
    color: #fffaf5;
    box-shadow:
      0 10px 20px rgba(0, 0, 0, 0.14),
      0 0 0 2px rgba(255, 255, 255, 0.96);
  }

  .coffee-marker__label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .coffee-marker.is-active .coffee-marker__halo,
  .coffee-marker:hover .coffee-marker__halo,
  .coffee-marker:focus-visible .coffee-marker__halo {
    transform: scale(1.24);
    opacity: 1;
  }

  .coffee-marker:focus-visible {
